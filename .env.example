# Resend (https://resend.com) — dipakai untuk mengirim email dari form kontak.
# 1. Daftar di resend.com, ambil API key dari dashboard.
# 2. Untuk testing cepat, sender "onboarding@resend.dev" sudah bisa langsung dipakai
#    tanpa verifikasi domain (lihat src/app/api/contact/route.ts).
# 3. Untuk produksi, verifikasi domain sendiri di Resend lalu ganti alamat "from".
RESEND_API_KEY=YOUR_API_KEY_HERE

# Alamat email tujuan — pesan dari form kontak akan dikirim ke sini.
CONTACT_TO_EMAIL=YOUR_EMAIL_HERE
